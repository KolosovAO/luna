{
  "name": "astrology-helper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "tsc --noEmit",
    "export:web": "expo export --platform web --output-dir dist",
    "build:pages": "npm run build && npm run export:web",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@expo/metro-runtime": "^56.0.15",
    "expo": "^56.0.12",
    "expo-status-bar": "^56.0.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-native": "^0.86.0",
    "react-native-svg": "^15.15.5",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/react": "^19.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
